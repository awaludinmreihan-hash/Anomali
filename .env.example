# Nama & identitas situs (ganti sesukamu, dipakai di judul, meta tag, dsb)
NEXT_PUBLIC_SITE_NAME="Anomali Nusantara"
NEXT_PUBLIC_SITE_DESCRIPTION="Arsip anomali, mitos, dan keanehan asli Indonesia."
NEXT_PUBLIC_SITE_URL="https://situskamu.vercel.app"

# Ambil dari Supabase Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Password buat login ke /admin (ganti dengan password kuat)
ADMIN_PASSWORD=
# Kunci rahasia buat menandatangani session login, isi string acak panjang
# generate contoh: openssl rand -hex 32
AUTH_SECRET=
